<math>
      <mn>X</mn>
      <mrow>
        <!-- mstyle is not space-like when it contains a non space-like element
             such as "mn". -->
        <mstyle id="mstyle2" class="testedElement">
          <mn>X</mn>
          <mspace width="25px" height="10px"/>
        </mstyle>
        <mo lspace="1em" rspace="0em">X</mo>
      </mrow>
      <mn>X</mn>
    </math>
