<math>
      <semantics>
        <mspace style="display: none; background: red;" width="50px" height="50px"/>
        <mspace style="background: red;" width="50px" height="50px"/>
        <annotation-xml style="display: inline-block" encoding="text/html">
          <span style="display: inline-block; width: 50px; height: 50px; background: green;"/>
        </annotation-xml>
      </semantics>
    </math>
